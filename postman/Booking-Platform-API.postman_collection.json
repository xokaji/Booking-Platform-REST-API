{
  "info": {
    "name": "Booking Platform API",
    "description": "Booking API for a service-based platform, allowing users to register, login, manage services, and handle bookings.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "serviceId", "value": "" },
    { "key": "bookingId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"name\": \"Jane Doe\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"StrongPass123!\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Classic Haircut\",\n  \"description\": \"A precision haircut.\",\n  \"duration\": 30,\n  \"price\": 25.0,\n  \"isActive\": true\n}" },
            "url": "{{baseUrl}}/services"
          }
        },
        {
          "name": "Get All Services",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/services?page=1&limit=10"
          }
        },
        {
          "name": "Get Service By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Update Service",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 30.0\n}" },
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        },
        {
          "name": "Delete Service",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking (Public)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customerName\": \"John Smith\",\n  \"customerEmail\": \"john.smith@example.com\",\n  \"customerPhone\": \"+94770000001\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"bookingDate\": \"2026-08-20\",\n  \"bookingTime\": \"14:00\",\n  \"notes\": \"Optional note\"\n}" },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/bookings?page=1&limit=10"
          }
        },
        {
          "name": "Get Booking By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Update Booking Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" },
            "url": "{{baseUrl}}/bookings/{{bookingId}}/status"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/bookings/{{bookingId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        { "name": "Health Check", "request": { "method": "GET", "url": "{{baseUrl}}/health" } }
      ]
    }
  ]
}
