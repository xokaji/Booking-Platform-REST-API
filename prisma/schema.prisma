// Prisma schema for the Booking Platform API

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  services  Service[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("users")
}

model Service {
  id          String    @id @default(uuid())
  title       String
  description String
  duration    Int // duration in minutes
  price       Decimal   @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId     String
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId])
  @@index([isActive])
  @@map("services")
}

model Booking {
  id            String        @id @default(uuid())
  customerName  String
  customerEmail String
  customerPhone String
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  serviceId     String
  bookingDate   DateTime      @db.Date
  bookingTime   String // stored as HH:mm, kept as string for simple comparison/display
  status        BookingStatus @default(PENDING)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Prevents two bookings for the same service, date and time at the DB level
  @@unique([serviceId, bookingDate, bookingTime], name: "uniqueServiceSlot")
  @@index([serviceId])
  @@index([status])
  @@index([bookingDate])
  @@map("bookings")
}
